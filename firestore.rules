rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'admin';
    }

    // ── Usuarios ──────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /progreso_cursos/{cursoId} {
        allow read, write: if isOwner(userId) || isAdmin();

        match /historial/{historialId} {
          allow read, write: if isOwner(userId) || isAdmin();
        }
      }

      match /insignias/{insigniaId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /perfil/{perfilId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // ── Contenido educativo (cursos, módulos, lecciones) ──────────────
    // Lectura para cualquier usuario autenticado, escritura solo admin.
    match /cursos/{cursoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();

      match /modulos/{moduloId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();

        match /lecciones/{leccionId} {
          allow read: if isSignedIn();
          allow write: if isAdmin();
        }
      }
    }

    // ── Ejercicios (colección raíz, referenciados por id) ─────────────
    match /ejercicios/{ejercicioId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Vocabulario / diccionario ──────────────────────────────────────
    match /palabras/{palabraId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Artículos de cultura ────────────────────────────────────────────
    match /articulos_cultura/{articuloId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Denegar todo lo demás por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
